{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=loggingapi;Username=postgres;Password=postgres"
  },
  "PasswordHasher": {
    "SaltSize": 16,
    "Iterations": 100000,
    "HashAlgorithmName": "SHA512",
    "HashSize": 32
  },
  "Tokens": {
    "AccessToken": {
      "Issuer": "LoggingApi",
      "Audience": "LoggingApi.Client",
      "Secret": "NOT_ACTUAL_SECRET_CHANGE_ME_BEFORE_PRODUCTION_32_CHAR_SECRET",
      "ExpirationInMinutes": "10"
    },
    "RefreshToken": {
      "ExpirationInDays": "30"
    }
  },
  "Email": {
    "Host": "mailpit",
    "Port": 1025,
    "FromAddress": "noreply@loggingapi.com",
    "FromName": "LoggingApi",
    "Limits": {
      "CriticalErrors": {
        "Max": 15,
        "PerMinutes": 5
      }
    }
  },
  "TwoFactor": {
    "RecoveryCodeAlphabet": "ABCDEFGHIJKLMNPQRSTUVWXYZ23456789",
    "QrCode": {
      "Issuer": "LoggingApi"
    }
  }
}
