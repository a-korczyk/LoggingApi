{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=loggingapi;Username=postgres;Password=postgres"
  },
  "PasswordHasher": {
    "SaltSize": 16,
    "Iterations": 100000,
    "HashAlgorithmName": "SHA512",
    "HashSize": 32
  },
  "Jwt": {
    "Issuer": "LoggingApi",
    "Audience": "LoggingApi.Client",
    "ExpirationInMinutes": "90"
  },
  "Email": {
    "Host": "mailpit",
    "Port": 1025,
    "FromAddress": "noreply@loggingapi.com",
    "FromName": "LoggingApi",
    "Limits": {
      "CriticalErrors": {
        "Max": 15,
        "PerMinutes": 5
      }
    }
  },
  "TwoFactor": {
    "RecoveryCodeAlphabet": "ABCDEFGHIJKLMNPQRSTUVWXYZ23456789",
    "QrCode": {
      "Issuer": "LoggingApi"
    }
  }
}
